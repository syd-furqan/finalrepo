<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Glitch" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>

        <!-- ── Brand palette ─────────────────────────────────────────── -->
        <item name="colorPrimary">@color/brand_blue_900</item>
        <item name="colorOnPrimary">@color/gf_text_on_dark</item>
        <item name="colorPrimaryContainer">@color/md_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/md_on_primary_container</item>

        <item name="colorSecondary">@color/brand_blue_700</item>
        <item name="colorOnSecondary">@color/md_on_secondary</item>
        <item name="colorSecondaryContainer">@color/md_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/md_on_secondary_container</item>

        <item name="colorTertiary">@color/brand_cyan</item>
        <item name="colorOnTertiary">@color/md_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/md_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/md_on_tertiary_container</item>

        <!-- ── Surfaces — white app ───────────────────────────────────── -->
        <item name="android:colorBackground">@color/gf_bg_surface</item>
        <item name="colorOnBackground">@color/gf_text_primary</item>
        <item name="colorSurface">@color/gf_bg_surface</item>
        <item name="colorOnSurface">@color/gf_text_primary</item>
        <item name="colorSurfaceVariant">@color/gf_bg_surface_dim</item>
        <item name="colorOnSurfaceVariant">@color/gf_text_secondary</item>
        <item name="colorOutline">@color/gf_border</item>
        <item name="colorOutlineVariant">@color/md_outline_variant</item>

        <item name="colorError">@color/gf_danger</item>
        <item name="colorOnError">@color/gf_text_on_accent</item>
        <item name="colorErrorContainer">@color/gf_danger_bg</item>
        <item name="colorOnErrorContainer">@color/md_on_error_container</item>

        <!-- ── System bars ────────────────────────────────────────────── -->
        <item name="android:statusBarColor">@color/gf_bg_surface</item>
        <item name="android:navigationBarColor">@color/gf_bg_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <!-- ── Typography — Inter font family ────────────────────────── -->
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>

        <item name="textAppearanceDisplayLarge">@style/TextAppearance.GateFlow.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.GateFlow.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.GateFlow.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.GateFlow.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.GateFlow.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.GateFlow.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.GateFlow.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.GateFlow.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.GateFlow.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.GateFlow.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.GateFlow.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.GateFlow.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.GateFlow.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.GateFlow.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.GateFlow.LabelSmall</item>

        <!-- ── Global component overrides ────────────────────────────── -->
        <item name="materialButtonStyle">@style/Widget.Glitch.Button</item>
        <item name="textInputStyle">@style/Widget.Glitch.TextInputLayout.Outlined</item>
        <item name="editTextStyle">@style/Widget.Glitch.TextInputEditText</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.GateFlow.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.GateFlow.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.GateFlow.Large</item>
        <item name="bottomSheetStyle">@style/Widget.GateFlow.BottomSheet</item>
        <item name="floatingActionButtonStyle">@style/Widget.GateFlow.FAB</item>
    </style>

    <style name="Theme.Glitch" parent="Base.Theme.Glitch" />

    <style name="ThemeOverlay.Glitch.AnnouncementInterrupt" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

</resources>
