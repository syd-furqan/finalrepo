<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/status_ribbon"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_status_ribbon"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="@dimen/gf_space_md"
    android:paddingTop="10dp"
    android:paddingEnd="@dimen/gf_space_md"
    android:paddingBottom="10dp">

    <!-- Live pulse dot -->
    <View
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_status_dot"
        android:layout_marginEnd="@dimen/gf_space_sm" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_system_status_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_fallback_title"
            android:textColor="@color/gf_text_on_dark"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_system_status_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="@string/status_fallback_message"
            android:textColor="@color/on_dark_medium"
            android:textSize="10sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_status_clock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="@string/status_clock_placeholder"
        android:textColor="@color/on_dark_medium"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/button_guard_language_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/gf_space_sm"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:paddingHorizontal="@dimen/gf_space_sm"
        android:paddingVertical="2dp"
        android:textColor="@color/gf_text_on_dark"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>
