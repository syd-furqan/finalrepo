<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/status_ribbon"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_status_ribbon"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="@dimen/space_16"
    android:paddingTop="@dimen/space_10"
    android:paddingEnd="@dimen/space_16"
    android:paddingBottom="@dimen/space_10">

    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@android:drawable/ic_secure"
        android:tint="@color/white" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_8"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_system_status_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/status_fallback_title"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_system_status_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="@string/status_fallback_message"
            android:textColor="@color/white"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_status_clock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_clock_placeholder"
        android:textColor="@color/md_primary_container"
        android:textSize="11sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_guard_language_toggle"
        style="@style/Widget.Glitch.Button.Text"
        android:layout_width="92dp"
        android:layout_height="36dp"
        android:layout_marginStart="@dimen/space_8"
        android:backgroundTint="@android:color/transparent"
        android:minWidth="0dp"
        android:paddingStart="@dimen/space_6"
        android:paddingEnd="@dimen/space_6"
        android:text="EN | ار"
        android:textAllCaps="false"
        android:textSize="13sp"
        android:textColor="@color/white"
        app:strokeColor="@color/md_primary_container"
        app:strokeWidth="@dimen/stroke_1"
        android:visibility="gone" />
</LinearLayout>
