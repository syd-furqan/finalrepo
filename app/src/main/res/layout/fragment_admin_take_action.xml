<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_base">

    <androidx.core.widget.NestedScrollView
        android:background="@android:color/transparent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/anim_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/gf_space_lg"
            android:paddingTop="@dimen/gf_grid_gap"
            android:paddingEnd="@dimen/gf_space_lg"
            android:paddingBottom="@dimen/gf_space_lg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/admin_take_action_title"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/admin_take_action_subtitle"
                android:textColor="#BFFFFFFF"
                android:textSize="13sp" />

            <!-- Audience card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                app:cardBackgroundColor="@color/gf_bg_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/gf_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_space_md">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/announce_audience_title"
                        android:textColor="@color/gf_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/check_announce_all_campus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:text="@string/announce_all_campus" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/check_announce_student"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/announce_role_student" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/check_announce_faculty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/announce_role_faculty" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/check_announce_guard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/announce_role_guard" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/check_announce_monitor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/announce_role_monitor" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Reason / Announcement card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                app:cardBackgroundColor="@color/gf_bg_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/gf_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_space_md">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/announce_message_title"
                        android:textColor="@color/gf_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.GateFlow.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:hint="@string/announce_message_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_announce_message"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top|start"
                            android:inputType="textMultiLine"
                            android:minLines="3" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- In-Gate Service Inhibition card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                app:cardBackgroundColor="@color/gf_bg_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/gf_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_space_md">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/inhibit_section_title"
                        android:textColor="@color/gf_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/check_inhibit_ingate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:text="@string/inhibit_enable_label" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/check_inhibit_student"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/inhibit_affect_student" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/check_inhibit_faculty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/inhibit_affect_faculty" />

                    <RadioGroup
                        android:id="@+id/group_inhibit_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/radio_inhibit_mode_timed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="@string/inhibit_mode_timed" />

                        <RadioButton
                            android:id="@+id/radio_inhibit_mode_manual"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/gf_space_md"
                            android:text="@string/inhibit_mode_manual" />
                    </RadioGroup>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/text_inhibit_ends_at"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/inhibit_end_not_set"
                            android:textColor="@color/gf_text_hint" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/button_pick_inhibit_end"
                            style="@style/Widget.Glitch.Button.Text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/inhibit_pick_end" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Current In-Gate Control State card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                app:cardBackgroundColor="@color/gf_bg_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/gf_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_space_md">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/current_control_title"
                        android:textColor="@color/gf_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_current_control_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:text="@string/current_control_load_failed"
                        android:textColor="@color/gf_text_hint"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_publish_announcement"
                style="@style/Widget.GateFlow.Button.White"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="@dimen/gf_space_md"
                android:text="@string/announce_publish_action"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_restore_services"
                style="@style/Widget.GateFlow.Button.Ghost"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:text="@string/restore_services_action"
                android:textAllCaps="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        layout="@layout/include_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
