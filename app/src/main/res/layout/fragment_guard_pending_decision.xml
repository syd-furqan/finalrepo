<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_base">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_guard_decision"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/gf_space_md"
            android:paddingTop="@dimen/gf_space_sm"
            android:paddingEnd="@dimen/gf_space_md"
            android:paddingBottom="@dimen/gf_space_xl">

            <View
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@color/primary_navy" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_lg"
                android:text="@string/guard_pending_title"
                android:textColor="@color/gf_text_on_dark"
                android:textSize="26sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                app:cardBackgroundColor="@color/gf_bg_surface"
                app:cardCornerRadius="@dimen/gf_card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/gf_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_card_padding">

                    <TextView
                        android:id="@+id/text_pending_guest_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/gf_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_pending_pass_code"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:fontFamily="monospace"
                        android:textColor="@color/gf_text_secondary"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/gf_space_md"
                        android:background="@color/gf_border" />

                    <TextView
                        android:id="@+id/text_pending_guest_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:textColor="@color/gf_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_pending_has_vehicle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:textColor="@color/gf_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_pending_created_at"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:textColor="@color/gf_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_pending_sponsor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:textColor="@color/gf_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_pending_sponsor_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:textColor="@color/gf_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_pending_sponsor_role"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:textColor="@color/gf_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_pending_method"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:textColor="@color/gf_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                app:cardBackgroundColor="@color/gf_bg_surface"
                app:cardCornerRadius="@dimen/gf_card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/gf_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="CNIC Verification"
                        android:textColor="@color/gf_text_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:text="@string/guard_pending_cnic_optional_hint"
                        android:textColor="@color/gf_text_hint"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:id="@+id/layout_cnic_manual_override"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layout_cnic_manual_input"
                            style="@style/Widget.GateFlow.TextInputLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/guest_cnic">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/input_cnic_manual"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="monospace"
                                android:inputType="number"
                                android:maxLength="15"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <ImageButton
                            android:id="@+id/button_verify_cnic_camera"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="@dimen/gf_space_sm"
                            android:background="@drawable/bg_icon_container"
                            android:contentDescription="Scan CNIC with camera"
                            android:padding="10dp"
                            android:src="@android:drawable/ic_menu_camera"
                            android:tint="@color/gf_accent" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_cnic_manual_verify"
                        style="@style/Widget.GateFlow.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/gf_button_height"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:text="@string/verify_action"
                        android:textAllCaps="false" />

                    <TextView
                        android:id="@+id/text_cnic_verify_result"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:paddingHorizontal="@dimen/gf_space_md"
                        android:paddingVertical="@dimen/gf_space_sm"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                app:cardBackgroundColor="@color/gf_bg_surface"
                app:cardCornerRadius="@dimen/gf_card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/gf_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_card_padding">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/check_pending_cnic_verified"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guard_checkpoint_cnic_verified"
                        android:textColor="@color/gf_text_primary"
                        android:textSize="14sp" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/check_pending_vehicle_verified"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guard_checkpoint_vehicle_verified"
                        android:textColor="@color/gf_text_primary"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_pending_allow"
                        style="@style/Widget.GateFlow.Button.Success"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/gf_button_height"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:text="@string/approve_entry"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_pending_deny"
                        style="@style/Widget.GateFlow.Button.Danger"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/gf_button_height"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:text="@string/deny_entry"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_pending_close"
                        style="@style/Widget.GateFlow.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/gf_button_height"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:text="@string/close_action"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        layout="@layout/include_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
