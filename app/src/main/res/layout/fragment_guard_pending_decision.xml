<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_24"
            android:paddingTop="@dimen/space_12"
            android:paddingEnd="@dimen/space_24"
            android:paddingBottom="@dimen/space_24">

            <include layout="@layout/include_status_ribbon" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24"
                android:text="@string/guard_pending_title"
                android:textColor="@color/text_dark"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:text="@string/guard_pending_subtitle"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="@dimen/space_16">

                <TextView
                    android:id="@+id/text_pending_guest_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_pending_pass_code"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_pending_method"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_pending_request_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_pending_guest_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <!-- CNIC scan row — camera only for guards -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_verify_cnic_camera"
                    style="@style/Widget.Glitch.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/guard_scan_physical_cnic"
                    android:textAllCaps="false"
                    android:textSize="13sp" />

                <!-- Result banner: match / mismatch / error -->
                <TextView
                    android:id="@+id/text_cnic_verify_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_6"
                    android:paddingHorizontal="@dimen/space_12"
                    android:paddingVertical="@dimen/space_8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- Manual override — only shown on mismatch -->
                <LinearLayout
                    android:id="@+id/layout_cnic_manual_override"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guard_cnic_manual_override_prompt"
                        android:textColor="@color/semantic_warning_on_container"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_6"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layout_cnic_manual_input"
                            style="@style/Widget.Glitch.TextInputLayout.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/guest_cnic">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/input_cnic_manual"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLength="15"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/button_cnic_manual_verify"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_8"
                            android:text="@string/verify_action"
                            android:textAllCaps="false" />

                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/text_pending_guest_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_pending_vehicle_plate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_pending_gate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_pending_sponsor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_pending_sponsor_role"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_pending_created_at"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_pending_expires_at"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:background="@color/surface_alt"
                android:orientation="vertical"
                android:padding="@dimen/space_16">

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/check_pending_vehicle_verified"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:text="@string/guard_checkpoint_vehicle_verified"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_pending_allow"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="@dimen/space_8"
                    android:backgroundTint="@color/md_tertiary"
                    android:text="@string/approve_entry"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_pending_deny"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="@dimen/space_8"
                    android:backgroundTint="@color/danger_red"
                    android:text="@string/deny_entry"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        layout="@layout/include_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
