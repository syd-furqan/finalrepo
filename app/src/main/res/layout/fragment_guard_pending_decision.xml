<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gf_bg_primary">

    <!-- ═══════════════════════════════════════════════
         PHASE 1 + 2: Main scroll content
         ═══════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_guard_decision"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/gf_space_md"
            android:paddingTop="@dimen/gf_space_sm"
            android:paddingEnd="@dimen/gf_space_md"
            android:paddingBottom="@dimen/gf_space_xl">


            <!-- Screen heading -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_lg"
                android:text="@string/guard_pending_title"
                android:textColor="@color/gf_text_on_dark"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_xs"
                android:text="@string/guard_pending_subtitle"
                android:textColor="@color/gf_text_secondary"
                android:textSize="14sp" />

            <!-- ─────────────────────────────────────
                 Guest identity card
                 ───────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                app:cardBackgroundColor="@color/gf_bg_surface"
                app:cardCornerRadius="@dimen/gf_card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/gf_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_card_padding">

                    <!-- Name + pass code row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_pending_guest_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/gf_text_primary"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/text_pending_pass_code"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/gf_space_xs"
                                android:fontFamily="monospace"
                                android:textColor="@color/gf_text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <!-- Guest type chip -->
                        <TextView
                            android:id="@+id/text_pending_guest_type"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/gf_space_sm"
                            android:background="@drawable/bg_chip_role"
                            android:paddingHorizontal="@dimen/gf_space_sm"
                            android:paddingVertical="4dp"
                            android:textColor="@color/gf_accent"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Details grid -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/gf_space_md"
                        android:background="@color/gf_border" />

                    <TextView
                        android:id="@+id/text_pending_guest_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:fontFamily="monospace"
                        android:textColor="@color/gf_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_pending_method"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:textColor="@color/gf_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_pending_gate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:textColor="@color/gf_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_pending_vehicle_plate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:textColor="@color/gf_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_pending_sponsor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:textColor="@color/gf_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_pending_sponsor_role"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:textColor="@color/gf_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/text_pending_created_at"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:textColor="@color/gf_text_hint"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/text_pending_expires_at"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:textColor="@color/gf_text_hint"
                        android:textSize="12sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─────────────────────────────────────
                 CNIC Verification card
                 ───────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                app:cardBackgroundColor="@color/gf_bg_surface"
                app:cardCornerRadius="@dimen/gf_card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/gf_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="CNIC Verification"
                        android:textColor="@color/gf_text_hint"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <!-- Scan CNIC button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_verify_cnic_camera"
                        style="@style/Widget.GateFlow.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/gf_button_height"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:text="@string/guard_scan_physical_cnic"
                        android:textAllCaps="false"
                        android:textSize="14sp" />

                    <!-- Result banner -->
                    <TextView
                        android:id="@+id/text_cnic_verify_result"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:paddingHorizontal="@dimen/gf_space_md"
                        android:paddingVertical="@dimen/gf_space_sm"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <!-- Manual override — shown on mismatch/failure -->
                    <LinearLayout
                        android:id="@+id/layout_cnic_manual_override"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/guard_cnic_manual_override_prompt"
                            android:textColor="@color/gf_warning"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/gf_space_sm"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layout_cnic_manual_input"
                                style="@style/Widget.GateFlow.TextInputLayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="@string/guest_cnic">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/input_cnic_manual"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="monospace"
                                    android:inputType="number"
                                    android:maxLength="15"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/button_cnic_manual_verify"
                                style="@style/Widget.GateFlow.Button.Primary"
                                android:layout_width="wrap_content"
                                android:layout_height="@dimen/gf_button_height"
                                android:layout_marginStart="@dimen/gf_space_sm"
                                android:text="@string/verify_action"
                                android:textAllCaps="false"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─────────────────────────────────────
                 Checkpoints + Action buttons card
                 ───────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                app:cardBackgroundColor="@color/gf_bg_surface"
                app:cardCornerRadius="@dimen/gf_card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/gf_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_card_padding">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/check_pending_vehicle_verified"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guard_checkpoint_vehicle_verified"
                        android:textColor="@color/gf_text_primary"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_pending_allow"
                        style="@style/Widget.GateFlow.Button.Success"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/gf_button_height"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:text="@string/approve_entry"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_pending_deny"
                        style="@style/Widget.GateFlow.Button.Danger"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/gf_button_height"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:text="@string/deny_entry"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ═══════════════════════════════════════════════
         PHASE 3: Full-screen result overlay
         SUCCESS state (green) — visibility toggled in code
         ═══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/overlay_cnic_result"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/gf_bg_primary"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/gf_space_xl"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Result icon circle -->
        <LinearLayout
            android:id="@+id/overlay_result_icon_container"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_icon_container_green"
            android:gravity="center">

            <ImageView
                android:id="@+id/overlay_result_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/checkbox_on_background"
                android:tint="@color/gf_success" />
        </LinearLayout>

        <!-- Result headline -->
        <TextView
            android:id="@+id/overlay_result_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gf_space_lg"
            android:gravity="center"
            android:text="Identity Verified"
            android:textColor="@color/gf_text_on_dark"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlay_result_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gf_space_sm"
            android:gravity="center"
            android:textColor="@color/gf_text_secondary"
            android:textSize="14sp" />

        <!-- Confirmed CNIC display -->
        <TextView
            android:id="@+id/overlay_result_cnic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gf_space_md"
            android:background="@drawable/bg_chip_role"
            android:fontFamily="monospace"
            android:paddingHorizontal="@dimen/gf_space_md"
            android:paddingVertical="@dimen/gf_space_sm"
            android:textColor="@color/gf_accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Primary action button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/overlay_button_primary"
            style="@style/Widget.GateFlow.Button.Success"
            android:layout_width="match_parent"
            android:layout_height="@dimen/gf_button_height"
            android:layout_marginTop="@dimen/gf_space_2xl"
            android:text="@string/approve_entry"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Secondary action button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/overlay_button_secondary"
            style="@style/Widget.GateFlow.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="@dimen/gf_button_height"
            android:layout_marginTop="@dimen/gf_space_sm"
            android:text="Back to Details"
            android:textAllCaps="false"
            android:textSize="14sp" />
    </LinearLayout>

    <include
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        layout="@layout/include_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
