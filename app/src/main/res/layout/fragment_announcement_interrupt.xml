<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:padding="@dimen/gf_space_lg">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/container_interrupt_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/gf_bg_surface"
        app:cardCornerRadius="@dimen/gf_card_radius"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.4">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/gf_space_lg">

            <!-- Channel label -->
            <TextView
                android:id="@+id/text_interrupt_channel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_role"
                android:paddingHorizontal="@dimen/gf_space_sm"
                android:paddingVertical="3dp"
                android:textAllCaps="true"
                android:textColor="@color/brand_blue_900"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Heading -->
            <TextView
                android:id="@+id/text_interrupt_heading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:text="@string/announcement_interrupt_heading"
                android:textColor="@color/gf_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01" />

            <!-- Title -->
            <TextView
                android:id="@+id/text_interrupt_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:textColor="@color/gf_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/gf_space_md"
                android:background="@color/gf_border" />

            <!-- Message -->
            <TextView
                android:id="@+id/text_interrupt_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                android:textColor="@color/gf_text_secondary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4" />

            <!-- Timestamp -->
            <TextView
                android:id="@+id/text_interrupt_timestamp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                android:fontFamily="monospace"
                android:textColor="@color/gf_text_hint"
                android:textSize="11sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_interrupt_acknowledge"
                style="@style/Widget.GateFlow.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/gf_button_height"
                android:layout_marginTop="@dimen/gf_space_lg"
                android:text="@string/announcement_interrupt_acknowledge"
                android:textAllCaps="false" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
