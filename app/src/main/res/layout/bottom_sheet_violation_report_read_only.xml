<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/space_24">

    <TextView
        android:id="@+id/text_violation_readonly_level"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chip_role"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:textColor="@color/primary_navy"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_violation_readonly_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:text="Violation Report"
        android:textColor="@color/text_dark"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_violation_readonly_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_12"
        android:textColor="@color/text_dark"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_close_violation_readonly"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="@dimen/space_16"
        android:text="@string/close_action"
        android:textAllCaps="false" />
</LinearLayout>
