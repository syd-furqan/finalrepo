<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/gf_screen_margin"
    android:paddingTop="@dimen/gf_space_lg"
    android:paddingEnd="@dimen/gf_screen_margin"
    android:paddingBottom="@dimen/gf_space_xl">

    <!-- Level chip -->
    <TextView
        android:id="@+id/text_violation_readonly_level"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chip_alert_warning"
        android:paddingHorizontal="@dimen/gf_space_sm"
        android:paddingVertical="3dp"
        android:textColor="@color/gf_warning"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textAllCaps="true" />

    <TextView
        android:id="@+id/text_violation_readonly_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_sm"
        android:text="Violation Report"
        android:textColor="@color/gf_text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="-0.01" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_md"
        app:cardBackgroundColor="@color/gf_bg_surface_dim"
        app:cardCornerRadius="@dimen/gf_card_radius"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <TextView
            android:id="@+id/text_violation_readonly_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/gf_space_md"
            android:textColor="@color/gf_text_secondary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_close_violation_readonly"
        style="@style/Widget.GateFlow.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="@dimen/gf_button_height"
        android:layout_marginTop="@dimen/gf_space_lg"
        android:text="@string/close_action"
        android:textAllCaps="false" />

</LinearLayout>
