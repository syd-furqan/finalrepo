<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/gf_screen_margin"
    android:paddingTop="@dimen/gf_space_lg"
    android:paddingEnd="@dimen/gf_screen_margin"
    android:paddingBottom="@dimen/gf_space_xl">

    <!-- Type chip -->
    <TextView
        android:id="@+id/text_notification_detail_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chip_role"
        android:paddingHorizontal="@dimen/gf_space_sm"
        android:paddingVertical="3dp"
        android:textColor="@color/brand_blue_900"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textAllCaps="true" />

    <!-- Title -->
    <TextView
        android:id="@+id/text_notification_detail_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_sm"
        android:textColor="@color/gf_text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="-0.01" />

    <!-- Message -->
    <TextView
        android:id="@+id/text_notification_detail_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_sm"
        android:textColor="@color/gf_text_hint"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.4" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/gf_space_md"
        android:background="@color/gf_border" />

    <!-- Meta -->
    <TextView
        android:id="@+id/text_notification_detail_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_md"
        android:fontFamily="monospace"
        android:textColor="@color/gf_text_hint"
        android:textSize="12sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_open_notification_source"
        style="@style/Widget.GateFlow.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/gf_button_height"
        android:layout_marginTop="@dimen/gf_space_lg"
        android:text="@string/open_related_action"
        android:textAllCaps="false"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_close_notification_details"
        style="@style/Widget.GateFlow.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="@dimen/gf_button_height"
        android:layout_marginTop="@dimen/gf_space_sm"
        android:text="@string/close_action"
        android:textAllCaps="false" />

</LinearLayout>
