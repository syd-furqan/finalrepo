<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/space_24">

    <TextView
        android:id="@+id/text_notification_detail_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chip_role"
        android:paddingHorizontal="@dimen/space_8"
        android:paddingVertical="@dimen/space_2"
        android:textColor="@color/md_primary"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_notification_detail_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:textColor="@color/text_dark"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_notification_detail_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:textColor="@color/text_muted"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/text_notification_detail_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_16"
        android:textColor="@color/text_dark"
        android:textSize="13sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_open_notification_source"
        style="@style/Widget.Glitch.Button"
        android:layout_width="match_parent"
        android:layout_height="@dimen/min_touch_target"
        android:layout_marginTop="@dimen/space_16"
        android:text="@string/open_related_action"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_close_notification_details"
        style="@style/Widget.Glitch.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="@dimen/min_touch_target"
        android:layout_marginTop="@dimen/space_8"
        android:text="@string/close_action"
        android:textAllCaps="false" />
</LinearLayout>
