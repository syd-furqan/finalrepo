<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/gf_screen_margin"
    android:paddingTop="@dimen/gf_space_lg"
    android:paddingEnd="@dimen/gf_screen_margin"
    android:paddingBottom="@dimen/gf_space_xl">

    <!-- Sheet heading -->
    <TextView
        android:id="@+id/text_details_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/details_sheet_title"
        android:textColor="@color/gf_text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="-0.01" />

    <TextView
        android:id="@+id/text_details_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/details_sheet_message"
        android:textColor="@color/gf_text_hint"
        android:textSize="13sp" />

    <!-- Identity card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_md"
        app:cardBackgroundColor="@color/gf_bg_surface"
        app:cardCornerRadius="@dimen/gf_card_radius"
        app:cardElevation="0dp"
        app:strokeColor="@color/gf_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/gf_space_md">

            <!-- Name + role chip -->
            <TextView
                android:id="@+id/text_request_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/gf_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_request_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_xs"
                android:background="@drawable/bg_chip_role"
                android:paddingHorizontal="@dimen/gf_space_sm"
                android:paddingVertical="2dp"
                android:textAllCaps="true"
                android:textColor="@color/brand_blue_900"
                android:textSize="10sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/gf_space_md"
                android:background="@color/gf_border" />

            <TextView
                android:id="@+id/text_visitor_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                android:fontFamily="monospace"
                android:textColor="@color/gf_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_request_host"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_request_gate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/gf_space_md"
                android:background="@color/gf_border" />

            <TextView
                android:id="@+id/text_request_entered"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                android:textColor="@color/gf_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_request_admitted_by"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_request_expiry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_danger"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_request_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                android:fontFamily="monospace"
                android:textColor="@color/gf_text_hint"
                android:textSize="10sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_md"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_close"
            style="@style/Widget.GateFlow.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="@dimen/gf_button_height"
            android:layout_weight="1"
            android:text="@string/close_action"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_sheet_log_exit"
            style="@style/Widget.GateFlow.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="@dimen/gf_button_height"
            android:layout_marginStart="@dimen/gf_space_sm"
            android:layout_weight="1"
            android:text="@string/log_exit_action"
            android:textAllCaps="false" />
    </LinearLayout>

</LinearLayout>
