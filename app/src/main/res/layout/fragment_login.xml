<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Fullscreen background photo -->
    <ImageView
        android:id="@+id/image_login_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        android:src="@drawable/login_bg_photo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Navy blue scrim over the photo -->
    <View
        android:id="@+id/view_login_scrim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#CC071F3D"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Brand section: logo + title, centred in the top half -->
    <LinearLayout
        android:id="@+id/layout_brand"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layout_form_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Shield logo — transparent PNG, no clipping -->
        <ImageView
            android:id="@+id/image_login_logo"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_login_logo"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="GateFlow"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Campus Guest Access System"
            android:textColor="#BFFFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.02" />

    </LinearLayout>

    <!-- White form card — anchored to bottom 50% -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/layout_form_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:background="@drawable/bg_login_form_card"
        app:layout_constraintTop_toBottomOf="@id/guideline_half"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="28dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome back"
                android:textColor="@color/gf_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Sign in with your campus credentials"
                android:textColor="@color/gf_text_hint"
                android:textSize="13sp" />

            <!-- Email -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_email"
                style="@style/Widget.Glitch.TextInputLayout.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:hint="@string/login_email"
                app:startIconDrawable="@android:drawable/ic_dialog_email"
                app:startIconTint="@color/gf_text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/gf_text_primary"
                    android:textSize="15sp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_password"
                style="@style/Widget.Glitch.TextInputLayout.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/login_password"
                app:passwordToggleEnabled="true"
                app:startIconDrawable="@android:drawable/ic_lock_lock"
                app:startIconTint="@color/gf_text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/gf_text_primary"
                    android:textSize="15sp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Forgot password -->
            <TextView
                android:id="@+id/text_login_help"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Use your assigned campus account. If access fails, contact admin (IST)."
                android:textColor="@color/brand_blue_700"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Sign In button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_login"
                style="@style/Widget.GateFlow.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="@string/login_action"
                android:textAllCaps="false"
                android:textSize="15sp" />

            <!-- Progress -->
            <ProgressBar
                android:id="@+id/progress_login"
                style="@android:style/Widget.Material.ProgressBar.Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:indeterminateTint="@color/gf_accent"
                android:visibility="gone" />

            <!-- Register button — kept GONE, ID must exist -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_register"
                style="@style/Widget.GateFlow.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="@dimen/gf_button_height"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:text="Create Account"
                android:textAllCaps="false"
                android:visibility="gone" />

            <!-- Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:fontFamily="monospace"
                android:text="GateFlow · Secured by Firebase"
                android:textColor="@color/gf_text_hint"
                android:textSize="11sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Guideline at 50% -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_half"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.50" />

</androidx.constraintlayout.widget.ConstraintLayout>
