<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gf_bg_surface"
    android:fitsSystemWindows="true">

    <!-- Fullscreen photo background. Place your image at
         res/drawable/login_bg_photo.jpg (or png/webp). -->
    <ImageView
        android:id="@+id/image_login_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        android:src="@drawable/login_bg_photo"
        android:alpha="1.0" />

    <!-- Light scrim over the photo for contrast with text -->
    <View
        android:id="@+id/view_login_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_scrim_low" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- ── Brand hero: navy gradient with wave-like bottom ──── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:gravity="bottom|center_horizontal"
                android:orientation="vertical"
                android:paddingBottom="28dp">

                <!-- Logo as circular image -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/image_login_logo"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_login_logo"
                    android:contentDescription="@null"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#FFFFFF"
                    app:cornerRadius="32dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif"
                    android:text="GateFlow"
                    android:textColor="@color/gf_text_on_dark"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.01" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif"
                    android:text="Campus Guest Access System"
                    android:textColor="@color/on_dark_medium"
                    android:textSize="13sp"
                    android:letterSpacing="0.02" />
            </LinearLayout>

            <!-- ── White form card lifted over hero ──────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="482dp"
                android:layout_marginTop="-8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_login_form_card"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="-0.01"
                    android:text="Welcome back"
                    android:textColor="@color/gf_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif"
                    android:text="Sign in with your campus credentials"
                    android:textColor="@color/gf_text_hint"
                    android:textSize="12sp" />

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_email"
                    style="@style/Widget.Glitch.TextInputLayout.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="28dp"
                    android:hint="@string/login_email"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="@color/gf_text_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/gf_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_password"
                    style="@style/Widget.Glitch.TextInputLayout.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:hint="@string/login_password"
                    app:passwordToggleEnabled="true"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:startIconTint="@color/gf_text_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:inputType="textPassword"
                        android:textColor="@color/gf_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Forgot password link -->
                <TextView
                    android:id="@+id/text_login_help"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:text="Forgot Password?"
                    android:textColor="@color/brand_blue_700"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Sign In button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_login"
                    style="@style/Widget.GateFlow.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="32dp"
                    android:fontFamily="sans-serif"
                    android:text="@string/login_action"
                    android:textAllCaps="false"
                    android:textSize="15sp" />

                <!-- Progress -->
                <ProgressBar
                    android:id="@+id/progress_login"
                    style="@android:style/Widget.Material.ProgressBar.Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/gf_space_sm"
                    android:indeterminateTint="@color/gf_accent"
                    android:visibility="gone" />

                <!--
                    Register button — kept GONE.
                    LoginFragment references this ID so it must exist.
                -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_register"
                    style="@style/Widget.GateFlow.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/gf_button_height"
                    android:layout_marginTop="@dimen/gf_space_sm"
                    android:text="Create Account"
                    android:textAllCaps="false"
                    android:visibility="gone" />

                <!-- Footer -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="GateFlow · Secured by Firebase"
                    android:textColor="@color/gf_text_hint"
                    android:textSize="11sp" />

                <!-- Spacer to push footer to bottom -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
