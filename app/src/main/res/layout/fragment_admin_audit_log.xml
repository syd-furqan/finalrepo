<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_base">

    <androidx.core.widget.NestedScrollView
        android:background="@android:color/transparent"
        android:id="@+id/scroll_audit_logs"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/anim_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Controls header — scrolls with the list -->
            <LinearLayout
                android:id="@+id/layout_audit_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/space_20"
                android:paddingTop="@dimen/gf_grid_gap"
                android:paddingEnd="@dimen/space_20"
                android:paddingBottom="@dimen/gf_grid_gap">


                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gf_grid_gap"
                    android:text="@string/audit_logs_title"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_filter_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gf_space_xs"
                    android:textColor="#BFFFFFFF"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_10"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_export_csv"
                        style="@style/Widget.GateFlow.Button.White"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/export_csv_short"
                        android:textAllCaps="false" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_export_pdf"
                        style="@style/Widget.GateFlow.Button.White"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/gf_space_sm"
                        android:layout_weight="1"
                        android:text="@string/export_pdf_short"
                        android:textAllCaps="false" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gf_space_sm"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_open_audit_filters"
                        style="@style/Widget.GateFlow.Button.White"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_filters"
                        android:textAllCaps="false" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_open_traffic_analytics"
                        style="@style/Widget.GateFlow.Button.White"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/gf_space_sm"
                        android:layout_weight="1"
                        android:text="@string/audit_traffic_analytics"
                        android:textAllCaps="false" />
                </LinearLayout>



                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Material3.CardView.Filled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_10"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:strokeColor="#44FFFFFF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/gf_grid_gap">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/audit_insights_title"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_6"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/text_insight_total_events"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/audit_insight_total_events_default"
                                android:textColor="#BFFFFFFF"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/text_insight_deny_rate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/audit_insight_deny_rate_default"
                                android:textColor="#BFFFFFFF"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/text_insight_alerts"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="end"
                                android:text="@string/audit_insight_alerts_default"
                                android:textColor="#BFFFFFFF"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/text_insight_top_guard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/gf_space_xs"
                            android:text="@string/audit_insight_top_guard_default"
                            android:textColor="#BFFFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/text_insight_top_reason"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_2"
                            android:text="@string/audit_insight_top_reason_default"
                            android:textColor="#BFFFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Empty state -->
            <TextView
                android:id="@+id/text_audit_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:gravity="center"
                android:padding="@dimen/gf_grid_gap"
                android:text="@string/no_audit_logs"
                android:textColor="#BFFFFFFF"
                android:visibility="gone" />

            <!-- Log list — nested scrolling disabled so NestedScrollView drives all scrolling -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_audit_logs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingStart="@dimen/gf_space_md"
                android:paddingTop="@dimen/space_6"
                android:paddingEnd="@dimen/gf_space_md"
                android:paddingBottom="@dimen/gf_space_md" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        layout="@layout/include_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
