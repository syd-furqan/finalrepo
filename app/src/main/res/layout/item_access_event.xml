<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/space_8"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical"
    android:padding="@dimen/space_16">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/text_event_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_role"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textColor="@color/primary_navy"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/text_event_outcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_6"
            android:background="@drawable/bg_chip_role"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textColor="@color/text_dark"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/text_event_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_8"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_event_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:textColor="@color/text_dark"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_event_actor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/text_muted"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/text_event_request_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/text_muted"
        android:textSize="12sp" />
</LinearLayout>
