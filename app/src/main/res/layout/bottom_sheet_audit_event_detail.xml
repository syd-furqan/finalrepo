<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/gf_screen_margin"
    android:paddingTop="@dimen/gf_space_lg"
    android:paddingEnd="@dimen/gf_screen_margin"
    android:paddingBottom="@dimen/gf_space_xl">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Audit Event Details"
        android:textColor="@color/gf_text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="-0.01" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_md"
        app:cardBackgroundColor="@color/gf_bg_surface_dim"
        app:cardCornerRadius="@dimen/gf_card_radius"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/gf_space_md">

            <TextView
                android:id="@+id/text_detail_event_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/gf_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_detail_outcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:background="@color/gf_border" />

            <TextView
                android:id="@+id/text_detail_actor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_detail_entity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_detail_request"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_detail_gate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_detail_source"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_text_hint"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/text_detail_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_text_hint"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/text_detail_created"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:textColor="@color/gf_text_hint"
                android:textSize="11sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:background="@color/gf_border" />

            <TextView
                android:id="@+id/text_detail_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4" />

            <TextView
                android:id="@+id/text_detail_metadata"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:background="@color/gf_bg_surface"
                android:fontFamily="monospace"
                android:padding="@dimen/gf_space_sm"
                android:textColor="@color/gf_text_hint"
                android:textSize="11sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
