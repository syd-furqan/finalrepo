<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/gf_grid_gap"
    app:cardBackgroundColor="@color/gf_bg_surface"
    app:cardCornerRadius="@dimen/gf_card_radius"
    app:cardElevation="0dp"
    app:strokeColor="@color/gf_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/gf_card_padding">

        <!-- Top row: guest name + status badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_pass_guest_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/gf_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_pass_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/gf_space_sm"
                android:background="@drawable/bg_chip_role"
                android:paddingHorizontal="@dimen/gf_space_sm"
                android:paddingVertical="4dp"
                android:textColor="@color/gf_accent"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- CNIC (masked) + expiry -->
        <TextView
            android:id="@+id/text_pass_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gf_space_xs"
            android:fontFamily="monospace"
            android:textColor="@color/gf_text_secondary"
            android:textSize="12sp" />

        <!-- QR code -->
        <ImageView
            android:id="@+id/image_pass_qr"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/gf_space_md"
            android:background="@color/gf_bg_surface"
            android:contentDescription="@string/scan_qr_code"
            android:padding="@dimen/gf_space_sm" />

        <TextView
            android:id="@+id/text_pass_expiry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gf_space_xs"
            android:gravity="center"
            android:textColor="@color/gf_text_hint"
            android:textSize="11sp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/gf_space_md"
            android:background="@color/gf_border" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gf_space_sm"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_share_pass"
                style="@style/Widget.GateFlow.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Share"
                android:textAllCaps="false"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_view_pass_details"
                style="@style/Widget.GateFlow.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/gf_space_sm"
                android:layout_weight="1"
                android:text="@string/details_action"
                android:textAllCaps="false"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_cancel_pass"
                style="@style/Widget.GateFlow.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/gf_space_sm"
                android:layout_weight="1"
                android:text="@string/cancel_pass_action"
                android:textAllCaps="false"
                android:textColor="@color/gf_danger"
                android:textSize="12sp"
                app:strokeColor="@color/gf_danger" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
