<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/gf_space_sm"
    app:cardBackgroundColor="@color/gf_bg_surface"
    app:cardCornerRadius="@dimen/gf_card_radius"
    app:cardElevation="0dp"
    app:strokeColor="@color/gf_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/gf_space_md">

        <!-- Header: level chip + status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_charge_violation_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_role"
                android:paddingHorizontal="@dimen/gf_space_sm"
                android:paddingVertical="3dp"
                android:textColor="@color/brand_blue_900"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/text_charge_status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/gf_text_hint"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_charge_guest_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gf_space_sm"
            android:textColor="@color/gf_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_charge_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace"
            android:textColor="@color/gf_text_hint"
            android:textSize="12sp" />

        <!-- Payment note — hidden until user taps Request Removal -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_payment_note"
            style="@style/Widget.Glitch.TextInputLayout.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gf_space_md"
            android:hint="Payment reference / note"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_payment_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_request_removal"
            style="@style/Widget.GateFlow.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="@dimen/gf_space_md"
            android:text="Request Removal"
            android:textAllCaps="false"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_confirm_removal_request"
            style="@style/Widget.GateFlow.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="@dimen/gf_space_sm"
            android:text="Submit Removal Request"
            android:textAllCaps="false"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
