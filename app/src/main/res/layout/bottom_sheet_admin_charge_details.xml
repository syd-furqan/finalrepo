<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/gf_screen_margin"
    android:paddingTop="@dimen/gf_space_lg"
    android:paddingEnd="@dimen/gf_screen_margin"
    android:paddingBottom="@dimen/gf_space_xl">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/charge_details_title"
        android:textColor="@color/gf_text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="-0.01" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_md"
        app:cardBackgroundColor="@color/gf_bg_surface_dim"
        app:cardCornerRadius="@dimen/gf_card_radius"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/gf_space_md">

            <TextView
                android:id="@+id/text_charge_detail_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/gf_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:background="@color/gf_border" />

            <TextView
                android:id="@+id/text_charge_detail_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:fontFamily="monospace"
                android:textColor="@color/gf_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/text_charge_detail_request_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:textColor="@color/gf_text_hint"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/text_charge_detail_alert_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:textColor="@color/gf_text_hint"
                android:textSize="12sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:background="@color/gf_border" />

            <TextView
                android:id="@+id/text_charge_detail_guest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_charge_detail_sponsor_uid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_text_hint"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/container_charge_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_md"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_charge_mark_paid"
            style="@style/Widget.GateFlow.Button.Success"
            android:layout_width="0dp"
            android:layout_height="@dimen/gf_button_height"
            android:layout_weight="1"
            android:text="@string/mark_charge_paid_action"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_charge_remove"
            style="@style/Widget.GateFlow.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="@dimen/gf_button_height"
            android:layout_marginStart="@dimen/gf_space_sm"
            android:layout_weight="1"
            android:text="@string/remove_charge_action"
            android:textAllCaps="false" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_charge_close"
        style="@style/Widget.Glitch.Button.Text"
        android:layout_width="match_parent"
        android:layout_height="@dimen/min_touch_target"
        android:layout_marginTop="@dimen/gf_space_xs"
        android:text="@string/close_action"
        android:textAllCaps="false" />

</LinearLayout>
