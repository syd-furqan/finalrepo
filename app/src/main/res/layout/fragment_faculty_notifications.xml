<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_base">

    <androidx.core.widget.NestedScrollView
        android:background="@android:color/transparent"
        android:id="@+id/notifications_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/anim_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/gf_space_lg"
            android:paddingTop="@dimen/gf_grid_gap"
            android:paddingEnd="@dimen/gf_space_lg"
            android:paddingBottom="@dimen/gf_space_md">


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notifications"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Guest passes, vehicles, violations, reviews, and fines."
                android:textColor="#BFFFFFFF"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/container_notification_filters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_filter_all_notifications"
                    style="@style/Widget.GateFlow.Button.Ghost"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="@dimen/gf_space_xs"
                    android:text="@string/notifications_filter_all"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_filter_announcements"
                    style="@style/Widget.GateFlow.Button.Ghost"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/nav_announcements"
                    android:textAllCaps="false"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_mark_all_read"
                style="@style/Widget.GateFlow.Button.Ghost"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/gf_space_xs"
                android:text="@string/mark_all_read_action"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_notifications_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                android:text="@string/no_notifications"
                android:textColor="#BFFFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_notifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_grid_gap"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="@dimen/gf_space_md" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        layout="@layout/include_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
