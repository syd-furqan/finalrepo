<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/space_8"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical"
    android:padding="@dimen/space_16">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/text_admin_vehicle_plate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/text_dark"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/text_admin_vehicle_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_role"
            android:paddingHorizontal="@dimen/space_8"
            android:paddingVertical="3dp"
            android:textColor="@color/primary_navy"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_admin_vehicle_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_6"
        android:textColor="@color/text_dark"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/text_admin_vehicle_requester"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4"
        android:textColor="@color/text_muted"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/text_admin_vehicle_submitted"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_muted"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/text_admin_vehicle_reviewed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_12"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_deny_vehicle"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginEnd="@dimen/space_8"
            android:background="@drawable/bg_chip_alert_critical"
            android:paddingHorizontal="@dimen/space_16"
            android:text="@string/vehicle_deny_action"
            android:textAllCaps="false"
            android:textColor="@color/danger_red"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_approve_vehicle"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/bg_chip_success"
            android:paddingHorizontal="@dimen/space_16"
            android:text="@string/vehicle_approve_action"
            android:textAllCaps="false"
            android:textColor="@color/success_green"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
