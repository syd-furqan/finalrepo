<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/text_registered_vehicle_plate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_dark"
            android:textStyle="bold"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/text_registered_vehicle_sticker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_success"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="@color/success_green"
            android:textStyle="bold"
            android:textSize="10sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_registered_vehicle_model"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_muted"
        android:textSize="13sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_request_vehicle_removal"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_chip_alert_critical"
        android:text="Request Removal"
        android:textAllCaps="false"
        android:textColor="@color/danger_red"
        android:textStyle="bold"
        android:textSize="12sp" />
</LinearLayout>
