<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/gf_space_sm"
    android:orientation="vertical"
    android:padding="@dimen/gf_space_md">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/text_access_guest_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/gf_text_primary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/text_access_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_role"
            android:paddingHorizontal="@dimen/gf_space_sm"
            android:paddingVertical="3dp"
            android:textColor="@color/gf_text_primary"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_access_gate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_6"
        android:textColor="@color/gf_text_hint"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/text_access_guest_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_xs"
        android:textColor="@color/gf_text_hint"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/text_access_submitted_at"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_xs"
        android:textColor="@color/gf_text_hint"
        android:textSize="11sp" />

</LinearLayout>
