<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/top_app_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="@dimen/space_24"
    android:paddingTop="@dimen/space_16"
    android:paddingEnd="@dimen/space_24"
    android:paddingBottom="@dimen/space_16">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/image_top_logo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@color/surface_alt"
            android:padding="@dimen/space_8"
            android:src="@mipmap/ic_launcher_round" />

        <TextView
            android:id="@+id/text_top_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_12"
            android:fontFamily="sans-serif-bold"
            android:text="@string/top_title_lums_security"
            android:textColor="@color/primary_navy"
            android:textSize="20sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/button_notifications"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/app_name"
        android:padding="@dimen/space_8"
        android:src="@android:drawable/ic_dialog_info"
        android:tint="@color/primary_navy" />
</LinearLayout>
