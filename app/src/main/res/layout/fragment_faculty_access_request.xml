<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_base">

    <androidx.core.widget.NestedScrollView
        android:background="@android:color/transparent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/anim_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/gf_space_lg"
            android:paddingTop="@dimen/gf_grid_gap"
            android:paddingEnd="@dimen/gf_space_lg"
            android:paddingBottom="@dimen/gf_space_lg">

            <View
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@color/primary_navy" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_lg"
                android:text="Create Guest Pass"
                android:textColor="@color/gf_text_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:text="Issue a digital authorization for campus access. Passes can be created only between 8:30 AM and 10:00 PM and expire at 10:30 PM."
                android:textColor="@color/gf_text_hint"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_lg"
                android:background="@color/gf_bg_surface_dim"
                android:orientation="vertical"
                android:padding="@dimen/gf_space_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GUEST FULL NAME"
                    android:textAllCaps="true"
                    android:textColor="@color/gf_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_guest_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_6"
                    android:hint="@string/guest_full_name">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_guest_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gf_grid_gap"
                    android:text="PHONE NUMBER"
                    android:textAllCaps="true"
                    android:textColor="@color/gf_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_6"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/spinner_guest_country_code"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="0.42"
                        android:background="@color/gf_bg_surface_dim"
                        android:paddingStart="@dimen/gf_space_sm"
                        android:paddingEnd="@dimen/gf_space_sm" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_guest_phone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/gf_space_sm"
                        android:layout_weight="0.58"
                        android:hint="@string/guest_phone">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_guest_phone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="12" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gf_grid_gap"
                    android:text="CNIC NUMBER"
                    android:textAllCaps="true"
                    android:textColor="@color/gf_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_6"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_guest_cnic"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/guest_cnic">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_guest_id"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <ImageButton
                        android:id="@+id/button_guest_cnic_camera"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="@dimen/gf_space_sm"
                        android:background="@color/gf_bg_surface_dim"
                        android:contentDescription="Scan CNIC with camera"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:tint="@color/primary_navy" />

                    <ImageButton
                        android:id="@+id/button_guest_cnic_gallery"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="@dimen/space_6"
                        android:background="@color/gf_bg_surface_dim"
                        android:contentDescription="Pick CNIC from gallery"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:tint="@color/primary_navy" />
                </LinearLayout>

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/check_guest_has_vehicle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gf_grid_gap"
                    android:text="@string/guest_has_vehicle" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_guest_vehicle_plate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gf_space_sm"
                    android:hint="@string/vehicle_plate_label"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_guest_vehicle_plate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapCharacters"
                        android:maxLength="8" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gf_grid_gap"
                    android:background="@color/gf_bg_surface_dim"
                    android:orientation="horizontal"
                    android:padding="@dimen/gf_grid_gap">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_dialog_info"
                        android:tint="@color/primary_navy" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/gf_space_sm"
                        android:layout_weight="1"
                        android:text="By generating this pass, you acknowledge responsibility for your guest’s adherence to campus security protocols."
                        android:textColor="@color/gf_text_hint"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_submit_request"
                    style="@style/Widget.Glitch.Button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="@dimen/gf_space_md"
                    android:text="Generate Digital Pass"
                    android:textAllCaps="false" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_guest_pass_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                android:text="No managed passes yet."
                android:textColor="@color/gf_text_hint"
                android:textStyle="bold"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_view_archived_passes"
                style="@style/Widget.Glitch.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:text="@string/view_archived_passes_action"
                android:textAllCaps="false" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_guest_passes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        layout="@layout/include_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
