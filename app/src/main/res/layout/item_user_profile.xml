<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/gf_space_sm"
    app:cardBackgroundColor="@color/gf_bg_surface"
    app:cardCornerRadius="@dimen/gf_card_radius"
    app:cardElevation="0dp"
    app:strokeColor="@color/gf_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/gf_space_md">

        <!-- Avatar circle -->
        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_avatar_box"
            android:gravity="center">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:tint="@color/gf_text_on_dark"
                android:contentDescription="@null" />
        </LinearLayout>

        <!-- Name + email/role -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/gf_space_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_user_display_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:textColor="@color/gf_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_user_email_role"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif"
                android:textColor="@color/gf_text_hint"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Edit icon -->
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="@dimen/gf_space_md"
            android:src="@android:drawable/ic_menu_edit"
            android:tint="@color/gf_text_hint"
            android:contentDescription="@null" />

        <!-- Active toggle -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_user_active"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
