<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gf_bg_surface">

    <include
        android:id="@+id/top_bar"
        layout="@layout/include_top_app_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/gf_screen_margin"
            android:paddingTop="@dimen/gf_space_md"
            android:paddingEnd="@dimen/gf_screen_margin"
            android:paddingBottom="@dimen/gf_space_xl">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Active In-Gate Pass"
                android:textColor="@color/gf_text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_xs"
                android:text="Guest access management and real-time pass control."
                android:textColor="@color/gf_text_hint"
                android:textSize="13sp" />

            <!-- Info card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                app:cardBackgroundColor="@color/gf_bg_surface_dim"
                app:cardCornerRadius="@dimen/gf_card_radius"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_space_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_role"
                        android:paddingHorizontal="@dimen/gf_space_sm"
                        android:paddingVertical="3dp"
                        android:text="REQUESTER COPY"
                        android:textAllCaps="true"
                        android:textColor="@color/brand_blue_900"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:text="Each issued pass appears below with a scannable QR image and share action."
                        android:textColor="@color/gf_text_hint"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:background="@color/gf_border" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:text="Single Entry Authorization"
                        android:textColor="@color/gf_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Passes can be created only between 8:30 AM and 10:00 PM and expire at 10:30 PM the same day."
                        android:textColor="@color/gf_text_hint"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Create pass form card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                app:cardBackgroundColor="@color/gf_bg_surface"
                app:cardCornerRadius="@dimen/gf_card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/gf_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_space_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NEW PASS"
                        android:textColor="@color/gf_text_hint"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_pass_guest_name"
                        style="@style/Widget.GateFlow.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:hint="@string/guest_full_name">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_pass_guest_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:orientation="horizontal">

                        <Spinner
                            android:id="@+id/spinner_pass_country_code"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="0.42"
                            android:background="@drawable/bg_action_row"
                            android:paddingStart="@dimen/gf_space_sm"
                            android:paddingEnd="@dimen/gf_space_sm" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layout_pass_guest_phone"
                            style="@style/Widget.GateFlow.TextInputLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/gf_space_sm"
                            android:layout_weight="0.58"
                            android:hint="@string/guest_phone">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/input_pass_guest_phone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLength="12" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layout_pass_guest_cnic"
                            style="@style/Widget.GateFlow.TextInputLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/guest_cnic">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/input_pass_guest_id"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <ImageButton
                            android:id="@+id/button_pass_cnic_camera"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="@dimen/gf_space_sm"
                            android:background="@drawable/bg_icon_container"
                            android:contentDescription="Scan CNIC with camera"
                            android:padding="10dp"
                            android:src="@android:drawable/ic_menu_camera"
                            android:tint="@color/gf_accent" />

                        <ImageButton
                            android:id="@+id/button_pass_cnic_gallery"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="@dimen/gf_space_sm"
                            android:background="@drawable/bg_icon_container"
                            android:contentDescription="Pick CNIC from gallery"
                            android:padding="10dp"
                            android:src="@android:drawable/ic_menu_gallery"
                            android:tint="@color/gf_accent" />
                    </LinearLayout>

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/check_pass_has_vehicle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:text="@string/guest_has_vehicle" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_pass_vehicle_plate"
                        style="@style/Widget.GateFlow.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:hint="@string/vehicle_plate_label"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_pass_vehicle_plate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:inputType="textCapCharacters"
                            android:maxLength="8" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_create_pass"
                        style="@style/Widget.GateFlow.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/gf_button_height"
                        android:layout_marginTop="@dimen/gf_space_md"
                        android:text="@string/create_pass_action"
                        android:textAllCaps="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Actions row -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_view_archived_passes"
                style="@style/Widget.GateFlow.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="@dimen/gf_space_md"
                android:text="@string/view_archived_passes_action"
                android:textAllCaps="false" />

            <TextView
                android:id="@+id/text_guest_pass_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_lg"
                android:gravity="center"
                android:text="No managed passes yet."
                android:textColor="@color/gf_text_hint"
                android:textSize="14sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_guest_passes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        layout="@layout/include_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
