<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/gf_screen_margin"
    android:paddingTop="@dimen/gf_space_lg"
    android:paddingEnd="@dimen/gf_screen_margin"
    android:paddingBottom="@dimen/gf_space_xl">

    <!-- Header row: icon + title + severity chip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_container_red"
            android:gravity="center">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_dialog_alert"
                android:tint="@color/gf_danger"
                android:contentDescription="@null" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_alert_sheet_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/gf_space_md"
            android:layout_weight="1"
            android:text="Security Alert Details"
            android:textColor="@color/gf_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01" />

        <TextView
            android:id="@+id/text_alert_incident_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/gf_space_sm"
            android:background="@drawable/bg_chip_role"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="@color/primary_navy"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true" />
    </LinearLayout>

    <!-- Message -->
    <TextView
        android:id="@+id/text_alert_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_md"
        android:textColor="@color/gf_text_secondary"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.4" />

    <!-- Detail card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_md"
        app:cardBackgroundColor="@color/gf_bg_surface_dim"
        app:cardCornerRadius="@dimen/gf_card_radius"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/gf_space_md">

            <!-- Reporter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Reporter"
                    android:textColor="@color/gf_text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/text_alert_guard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/gf_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Visitor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_alert_subject_label"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Visitor"
                    android:textColor="@color/gf_text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/text_alert_visitor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/gf_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Sponsor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_alert_owner_label"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Sponsor"
                    android:textColor="@color/gf_text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/text_alert_sponsor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/gf_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Gate -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Gate"
                    android:textColor="@color/gf_text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/text_alert_gate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/gf_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Reason -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Reason"
                    android:textColor="@color/gf_text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/text_alert_reason"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/gf_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Intervention (only shown if not N/A) -->
            <LinearLayout
                android:id="@+id/row_intervention"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Action"
                    android:textColor="@color/gf_text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/text_alert_intervention_summary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/gf_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Actions -->
    <LinearLayout
        android:id="@+id/container_alert_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_md"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_alert_log_exit"
            style="@style/Widget.GateFlow.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="@dimen/gf_button_height"
            android:layout_weight="1"
            android:text="@string/log_exit_action"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_alert_charge"
            style="@style/Widget.GateFlow.Button.Danger"
            android:layout_width="0dp"
            android:layout_height="@dimen/gf_button_height"
            android:layout_marginStart="@dimen/gf_space_sm"
            android:layout_weight="1"
            android:text="@string/charge_action"
            android:textAllCaps="false" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_alert_close"
        style="@style/Widget.Glitch.Button.Text"
        android:layout_width="match_parent"
        android:layout_height="@dimen/min_touch_target"
        android:layout_marginTop="@dimen/gf_space_xs"
        android:text="@string/close_action"
        android:textAllCaps="false" />

    <!-- Hidden — kept for fragment binding compatibility -->
    <TextView
        android:id="@+id/text_alert_source"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</LinearLayout>
