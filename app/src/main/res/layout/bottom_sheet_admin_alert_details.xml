<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/gf_screen_margin"
    android:paddingTop="@dimen/gf_space_lg"
    android:paddingEnd="@dimen/gf_screen_margin"
    android:paddingBottom="@dimen/gf_space_xl">

    <!-- Header row: danger icon + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_container_red"
            android:gravity="center">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_dialog_alert"
                android:tint="@color/gf_danger"
                android:contentDescription="@null" />
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/gf_space_md"
            android:layout_weight="1"
            android:text="Security Alert Details"
            android:textColor="@color/gf_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01" />
    </LinearLayout>

    <!-- Detail card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_md"
        app:cardBackgroundColor="@color/gf_bg_surface_dim"
        app:cardCornerRadius="@dimen/gf_card_radius"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/gf_space_md">

            <TextView
                android:id="@+id/text_alert_incident_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/gf_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_alert_intervention_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:background="@color/gf_border" />

            <TextView
                android:id="@+id/text_alert_guard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_alert_visitor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_alert_sponsor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_alert_gate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_alert_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/gf_text_hint"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_alert_source"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:textColor="@color/gf_text_hint"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/text_alert_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:textColor="@color/gf_text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Actions -->
    <LinearLayout
        android:id="@+id/container_alert_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/gf_space_md"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_alert_log_exit"
            style="@style/Widget.GateFlow.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="@dimen/gf_button_height"
            android:layout_weight="1"
            android:text="@string/log_exit_action"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_alert_charge"
            style="@style/Widget.GateFlow.Button.Danger"
            android:layout_width="0dp"
            android:layout_height="@dimen/gf_button_height"
            android:layout_marginStart="@dimen/gf_space_sm"
            android:layout_weight="1"
            android:text="@string/charge_action"
            android:textAllCaps="false" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_alert_close"
        style="@style/Widget.Glitch.Button.Text"
        android:layout_width="match_parent"
        android:layout_height="@dimen/min_touch_target"
        android:layout_marginTop="@dimen/gf_space_xs"
        android:text="@string/close_action"
        android:textAllCaps="false" />

</LinearLayout>
