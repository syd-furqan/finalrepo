<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboard_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gf_bg_surface">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/content_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="@dimen/gf_space_md"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/gf_screen_margin"
            android:paddingTop="@dimen/gf_space_sm"
            android:paddingEnd="@dimen/gf_screen_margin">


            <!-- ── Quick action card ──────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                app:cardBackgroundColor="@color/gf_bg_surface"
                app:cardCornerRadius="@dimen/gf_card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/gf_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_space_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="@string/gate_protocol"
                        android:textColor="@color/gf_text_hint"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true" />

                    <!-- Scan QR action row -->
                    <LinearLayout
                        android:id="@+id/button_scan_qr"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:background="@drawable/bg_action_row"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/gf_space_md"
                        android:paddingEnd="@dimen/gf_space_md">

                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icon_container"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@android:drawable/ic_menu_camera"
                                android:tint="@color/gf_accent" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/gf_space_md"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif"
                            android:text="@string/scan_qr_code"
                            android:textColor="@color/gf_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_media_play"
                            android:tint="@color/gf_text_hint" />
                    </LinearLayout>

                    <!-- Manual entry action row -->
                    <LinearLayout
                        android:id="@+id/button_manual_entry"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="@dimen/gf_space_sm"
                        android:background="@drawable/bg_action_row"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/gf_space_md"
                        android:paddingEnd="@dimen/gf_space_md">

                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icon_container"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@android:drawable/ic_menu_edit"
                                android:tint="@color/gf_accent" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/gf_space_md"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif"
                            android:text="@string/manual_entry"
                            android:textColor="@color/gf_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_media_play"
                            android:tint="@color/gf_text_hint" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Protocol level card ────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                app:cardBackgroundColor="@color/md_primary_container"
                app:cardCornerRadius="@dimen/gf_card_radius"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_space_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="@string/current_protocol"
                        android:textColor="@color/md_on_primary_container"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true" />

                    <TextView
                        android:id="@+id/text_protocol_level"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:fontFamily="sans-serif"
                        android:text="@string/protocol_fallback_level"
                        android:textColor="@color/brand_blue_900"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.01" />

                    <TextView
                        android:id="@+id/text_protocol_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_xs"
                        android:fontFamily="sans-serif"
                        android:text="@string/protocol_fallback_description"
                        android:textColor="@color/md_on_primary_container"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Search bar ─────────────────────────────────────── -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_lg"
                android:hint="@string/search_hint"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:startIconTint="@color/gf_text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_search_requests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Section header row ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_lg"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif"
                    android:text="@string/active_entry_requests"
                    android:textColor="@color/gf_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.01" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="@string/label_view_all"
                    android:textColor="@color/brand_blue_700"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Loading state -->
            <LinearLayout
                android:id="@+id/loading_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_lg"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="@dimen/gf_space_xl">

                <ProgressBar
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:indeterminateTint="@color/gf_accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gf_space_sm"
                    android:fontFamily="sans-serif"
                    android:text="@string/loading_label"
                    android:textColor="@color/gf_text_hint"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Empty state -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/empty_state_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_md"
                android:visibility="gone"
                app:cardBackgroundColor="@color/gf_bg_surface_dim"
                app:cardCornerRadius="@dimen/gf_card_radius"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/gf_space_xl">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        android:tint="@color/gf_text_hint"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/gf_space_md"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:text="@string/empty_requests_title"
                        android:textColor="@color/gf_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:text="@string/empty_requests_body"
                        android:textColor="@color/gf_text_hint"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/requests_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gf_space_sm"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_action"
        android:layout_width="@dimen/fab_size_primary"
        android:layout_height="@dimen/fab_size_primary"
        android:layout_marginEnd="@dimen/gf_space_lg"
        android:layout_marginBottom="@dimen/space_32"
        android:contentDescription="@string/fab_label"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/brand_blue_900"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/white" />

    <include
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        layout="@layout/include_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
