@startuml
title GLITCH Android App - Simplified Class Diagram

left to right direction
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam ranksep 50
skinparam nodesep 30

package "app/core" {
  class MainActivity <<Activity>>
  interface NavigationHost
}

package "ui" {
  class LoginFragment <<Fragment>>
  class RoleHomeFragment <<Fragment>>
  class DashboardFragment <<Fragment>>
  class RoleNavRouter <<Router>>
}

package "auth" {
  interface AuthRepository
  class FirebaseAuthRepository
  class SessionManager <<Singleton>>
}

package "data" {
  class RepositoryProvider <<ServiceLocator>>

  interface EntryRequestRepository
  interface NotificationRepository

  class FirestoreEntryRequestRepository
  class FirestoreNotificationRepository
}

package "model" {
  class UserProfile
  class EntryRequest
  class NotificationItem
}

' Navigation and app flow
MainActivity ..|> NavigationHost
MainActivity --> LoginFragment
MainActivity --> RoleHomeFragment
RoleHomeFragment --> DashboardFragment
DashboardFragment --> RoleNavRouter
RoleNavRouter --> NavigationHost

' Auth flow
LoginFragment --> AuthRepository
FirebaseAuthRepository ..|> AuthRepository
AuthRepository --> UserProfile
SessionManager --> UserProfile

' Data flow
MainActivity --> RepositoryProvider
DashboardFragment --> EntryRequestRepository
DashboardFragment --> NotificationRepository
RepositoryProvider --> EntryRequestRepository
RepositoryProvider --> NotificationRepository
FirestoreEntryRequestRepository ..|> EntryRequestRepository
FirestoreNotificationRepository ..|> NotificationRepository

EntryRequestRepository --> EntryRequest
NotificationRepository --> NotificationItem

note bottom
  This is a high-level architecture view.
  Detailed role-specific screens and repositories are intentionally omitted.
end note

@enduml
